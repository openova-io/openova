---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/shared/Section.astro';
import SectionTitle from '../components/shared/SectionTitle.astro';
import Card from '../components/shared/Card.astro';
import Badge from '../components/shared/Badge.astro';
import Button from '../components/shared/Button.astro';
import { components } from '../data/components';

const coreComponents = components.filter(c => c.type === 'core');
const alacarteComponents = components.filter(c => c.type === 'alacarte');

const licenseMap: Record<string, string> = {
  'opentofu': 'MPL 2.0',
  'crossplane': 'Apache 2.0',
  'cilium': 'Apache 2.0',
  'envoy': 'Apache 2.0',
  'coraza': 'Apache 2.0',
  'external-dns': 'Apache 2.0',
  'k8gb': 'Apache 2.0',
  'flux': 'Apache 2.0',
  'gitea': 'MIT',
  'cert-manager': 'Apache 2.0',
  'external-secrets': 'Apache 2.0',
  'openbao': 'MPL 2.0',
  'trivy': 'Apache 2.0',
  'falco': 'Apache 2.0',
  'sigstore': 'Apache 2.0',
  'syft-grype': 'Apache 2.0',
  'kyverno': 'Apache 2.0',
  'vpa': 'Apache 2.0',
  'keda': 'Apache 2.0',
  'reloader': 'Apache 2.0',
  'grafana': 'AGPL 3.0',
  'opentelemetry': 'Apache 2.0',
  'opensearch': 'Apache 2.0',
  'harbor': 'Apache 2.0',
  'minio': 'AGPL 3.0',
  'velero': 'Apache 2.0',
  'continuum': 'Apache 2.0',
  'cnpg': 'Apache 2.0',
  'ferretdb': 'Apache 2.0',
  'strimzi': 'Apache 2.0',
  'valkey': 'BSD 3-Clause',
  'clickhouse': 'Apache 2.0',
  'stalwart': 'AGPL 3.0',
  'stunner': 'MIT',
  'livekit': 'Apache 2.0',
  'matrix': 'Apache 2.0',
  'ntfy': 'Apache 2.0 / GPL 2.0',
  'temporal': 'MIT',
  'flink': 'Apache 2.0',
  'debezium': 'Apache 2.0',
  'iceberg': 'Apache 2.0',
  'kserve': 'Apache 2.0',
  'knative': 'Apache 2.0',
  'vllm': 'Apache 2.0',
  'milvus': 'Apache 2.0',
  'neo4j': 'GPL 3.0 (CE)',
  'librechat': 'MIT',
  'bge': 'MIT',
  'llm-gateway': 'Apache 2.0',
  'anthropic-adapter': 'Apache 2.0',
  'nemo-guardrails': 'Apache 2.0',
  'langfuse': 'MIT',
  'keycloak': 'Apache 2.0',
  'openmeter': 'Apache 2.0',
  'litmus': 'Apache 2.0',
};

const upstreamLinks: Record<string, string> = {
  'opentofu': 'https://opentofu.org',
  'crossplane': 'https://crossplane.io',
  'cilium': 'https://cilium.io',
  'envoy': 'https://envoyproxy.io',
  'coraza': 'https://coraza.io',
  'external-dns': 'https://github.com/kubernetes-sigs/external-dns',
  'k8gb': 'https://k8gb.io',
  'flux': 'https://fluxcd.io',
  'gitea': 'https://gitea.io',
  'cert-manager': 'https://cert-manager.io',
  'external-secrets': 'https://external-secrets.io',
  'openbao': 'https://openbao.org',
  'trivy': 'https://trivy.dev',
  'falco': 'https://falco.org',
  'sigstore': 'https://sigstore.dev',
  'syft-grype': 'https://github.com/anchore/syft',
  'kyverno': 'https://kyverno.io',
  'vpa': 'https://github.com/kubernetes/autoscaler/tree/master/vertical-pod-autoscaler',
  'keda': 'https://keda.sh',
  'reloader': 'https://github.com/stakater/Reloader',
  'grafana': 'https://grafana.com',
  'opentelemetry': 'https://opentelemetry.io',
  'opensearch': 'https://opensearch.org',
  'harbor': 'https://goharbor.io',
  'minio': 'https://min.io',
  'velero': 'https://velero.io',
  'cnpg': 'https://cloudnative-pg.io',
  'ferretdb': 'https://ferretdb.com',
  'strimzi': 'https://strimzi.io',
  'valkey': 'https://valkey.io',
  'clickhouse': 'https://clickhouse.com',
  'stalwart': 'https://stalw.art',
  'stunner': 'https://github.com/l7mp/stunner',
  'livekit': 'https://livekit.io',
  'matrix': 'https://matrix.org',
  'ntfy': 'https://ntfy.sh',
  'temporal': 'https://temporal.io',
  'flink': 'https://flink.apache.org',
  'debezium': 'https://debezium.io',
  'iceberg': 'https://iceberg.apache.org',
  'kserve': 'https://kserve.github.io/website',
  'knative': 'https://knative.dev',
  'vllm': 'https://vllm.ai',
  'milvus': 'https://milvus.io',
  'neo4j': 'https://neo4j.com',
  'librechat': 'https://librechat.ai',
  'bge': 'https://huggingface.co/BAAI/bge-base-en-v1.5',
  'nemo-guardrails': 'https://github.com/NVIDIA/NeMo-Guardrails',
  'langfuse': 'https://langfuse.com',
  'keycloak': 'https://keycloak.org',
  'openmeter': 'https://openmeter.io',
  'litmus': 'https://litmuschaos.io',
};
---

<BaseLayout
  title="Docs — OpenOva"
  description="Licensing, support model, and reference documentation for the OpenOva platform."
  path="/docs"
>
  <!-- Hero -->
  <Section>
    <div class="mx-auto max-w-3xl text-center">
      <Badge variant="accent" class="mb-6">Documentation</Badge>
      <h1 class="text-4xl font-extrabold text-text-primary md:text-5xl">
        Licensing &amp; reference
      </h1>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        Every component is upstream open source. This page documents the license, category, and upstream link for every component in the platform.
      </p>
    </div>
  </Section>

  <!-- Core Components -->
  <Section bg="secondary">
    <SectionTitle label={`${coreComponents.length} core`}>
      Core platform components
    </SectionTitle>

    <p class="mb-8 max-w-2xl text-text-secondary text-sm reveal">
      Core components ship with every OpenOva deployment. They form the operational foundation: networking, security, GitOps, observability, storage, and scaling.
    </p>

    <div class="overflow-x-auto reveal">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border-primary">
            <th class="py-3 pr-4 text-left font-medium text-text-primary">Component</th>
            <th class="py-3 px-4 text-left font-medium text-text-primary">Purpose</th>
            <th class="py-3 px-4 text-left font-medium text-text-primary">License</th>
            <th class="py-3 pl-4 text-left font-medium text-text-primary">Upstream</th>
          </tr>
        </thead>
        <tbody class="text-text-secondary">
          {coreComponents.map((comp) => (
            <tr class="border-b border-border-primary/50">
              <td class="py-2.5 pr-4 font-medium text-text-primary">{comp.name}</td>
              <td class="py-2.5 px-4 text-xs">{comp.purpose}</td>
              <td class="py-2.5 px-4">
                <Badge variant="outline">{licenseMap[comp.slug] || 'Apache 2.0'}</Badge>
              </td>
              <td class="py-2.5 pl-4">
                {upstreamLinks[comp.slug] ? (
                  <a href={upstreamLinks[comp.slug]} target="_blank" rel="noopener" class="text-xs text-accent hover:underline">
                    Link
                  </a>
                ) : (
                  <span class="text-xs text-text-tertiary">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <!-- A La Carte Components -->
  <Section>
    <SectionTitle label={`${alacarteComponents.length} a la carte`}>
      A la carte components
    </SectionTitle>

    <p class="mb-8 max-w-2xl text-text-secondary text-sm reveal">
      A la carte components are optional services deployed based on workload requirements. Data, AI/ML, communication, identity, workflow, and analytics services.
    </p>

    <div class="overflow-x-auto reveal">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border-primary">
            <th class="py-3 pr-4 text-left font-medium text-text-primary">Component</th>
            <th class="py-3 px-4 text-left font-medium text-text-primary">Purpose</th>
            <th class="py-3 px-4 text-left font-medium text-text-primary">License</th>
            <th class="py-3 pl-4 text-left font-medium text-text-primary">Upstream</th>
          </tr>
        </thead>
        <tbody class="text-text-secondary">
          {alacarteComponents.map((comp) => (
            <tr class="border-b border-border-primary/50">
              <td class="py-2.5 pr-4 font-medium text-text-primary">{comp.name}</td>
              <td class="py-2.5 px-4 text-xs">{comp.purpose}</td>
              <td class="py-2.5 px-4">
                <Badge variant="outline">{licenseMap[comp.slug] || 'Apache 2.0'}</Badge>
              </td>
              <td class="py-2.5 pl-4">
                {upstreamLinks[comp.slug] ? (
                  <a href={upstreamLinks[comp.slug]} target="_blank" rel="noopener" class="text-xs text-accent hover:underline">
                    Link
                  </a>
                ) : (
                  <span class="text-xs text-text-tertiary">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <!-- Support Model -->
  <Section bg="secondary">
    <SectionTitle label="Support">
      Support model
    </SectionTitle>

    <div class="grid gap-8 md:grid-cols-2 reveal-children">
      <div class="rounded-xl border border-accent/20 bg-bg-primary p-8">
        <div class="mb-6 flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-accent"></span>
          <h3 class="text-lg font-semibold text-text-primary">All software free</h3>
        </div>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Every platform component — free forever
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            All blueprints and manifests — open source
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Community edition = enterprise edition
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Self-service deployment — no gates
          </li>
        </ul>
      </div>

      <div class="rounded-xl border border-border-primary bg-bg-primary p-8">
        <div class="mb-6 flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-text-tertiary"></span>
          <h3 class="text-lg font-semibold text-text-primary">Per-vCPU-core subscription</h3>
        </div>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li class="flex items-start gap-2">
            <span class="text-text-tertiary mt-0.5 flex-shrink-0">&mdash;</span>
            Platform support SLA
          </li>
          <li class="flex items-start gap-2">
            <span class="text-text-tertiary mt-0.5 flex-shrink-0">&mdash;</span>
            Upgrade lifecycle management
          </li>
          <li class="flex items-start gap-2">
            <span class="text-text-tertiary mt-0.5 flex-shrink-0">&mdash;</span>
            Specter AI operational agents
          </li>
          <li class="flex items-start gap-2">
            <span class="text-text-tertiary mt-0.5 flex-shrink-0">&mdash;</span>
            Expert network access
          </li>
        </ul>
      </div>
    </div>
  </Section>

  <!-- Getting Started -->
  <Section>
    <SectionTitle label="Get started">
      Quick start
    </SectionTitle>

    <div class="grid gap-6 sm:grid-cols-3 reveal-children">
      <Card>
        <h3 class="mb-2 font-semibold text-text-primary text-sm">1. Browse the platform</h3>
        <p class="text-xs text-text-secondary mb-4">Explore every component, how they integrate, and what they do.</p>
        <Button href="/platform" variant="secondary">Platform</Button>
      </Card>
      <Card>
        <h3 class="mb-2 font-semibold text-text-primary text-sm">2. Choose your path</h3>
        <p class="text-xs text-text-secondary mb-4">Discover, Transform, or Operate — pick your entry point.</p>
        <Button href="/engagement" variant="secondary">Engagement</Button>
      </Card>
      <Card>
        <h3 class="mb-2 font-semibold text-text-primary text-sm">3. Talk to us</h3>
        <p class="text-xs text-text-secondary mb-4">Start a conversation. No sales pitch, just engineering.</p>
        <Button href="/contact" variant="secondary">Contact</Button>
      </Card>
    </div>
  </Section>

  <!-- FAQ -->
  <Section bg="secondary">
    <SectionTitle label="FAQ">
      Common questions
    </SectionTitle>

    <div class="mx-auto max-w-3xl space-y-6 reveal-children">
      {[
        {
          q: 'Is all the software really free?',
          a: 'Yes. Every component, every blueprint, every manifest is free and open source. We charge only for per-vCPU-core platform support subscriptions. There is no feature gating, no open-core model, no freemium trap.',
        },
        {
          q: 'What happens if I stop paying for support?',
          a: 'Nothing breaks. Everything keeps running. You keep all code, all configurations, all blueprints. You lose the support SLA, Specter AI agents, upgrade lifecycle management, and expert network access. That is the exit strategy: do nothing.',
        },
        {
          q: 'Why per-vCPU-core pricing?',
          a: 'It scales linearly with actual infrastructure. No per-component charges, no per-node gotchas, no per-seat surprises. One metric covers the entire platform — every component for one subscription price.',
        },
        {
          q: 'Can I deploy without OpenOva support?',
          a: 'Absolutely. All blueprints are public. You can deploy the entire platform yourself. Many organizations start self-service and add support later when they need operational guarantees.',
        },
        {
          q: 'What licenses should I be aware of?',
          a: 'Most components use Apache 2.0. Notable exceptions: Grafana and MinIO (AGPL 3.0), OpenTofu and OpenBao (MPL 2.0), Neo4j Community Edition (GPL 3.0), Gitea (MIT). See the tables above for the full list.',
        },
        {
          q: 'How does OpenOva differ from Red Hat OpenShift?',
          a: 'OpenOva curates upstream open-source components — we don\'t fork or wrap them. You use the actual projects. We add proven interoperability blueprints and AI-native operations (Specter). You don\'t pay more for using more components.',
        },
      ].map((faq) => (
        <div class="rounded-xl border border-border-primary bg-bg-primary p-6">
          <h3 class="font-semibold text-text-primary mb-2">{faq.q}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section>
    <div class="mx-auto max-w-2xl text-center reveal">
      <h2 class="text-3xl font-bold text-text-primary">Need something specific?</h2>
      <p class="mt-4 text-text-secondary">This documentation will grow. For now, the fastest way to get answers is to talk to us directly.</p>
      <div class="mt-8">
        <Button href="/contact">Talk to us</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/shared/Section.astro';
import SectionTitle from '../components/shared/SectionTitle.astro';
import Card from '../components/shared/Card.astro';
import Badge from '../components/shared/Badge.astro';
import Button from '../components/shared/Button.astro';
import ComponentGrid from '../components/islands/ComponentGrid.svelte';
import BuildingBlocksDiagram from '../components/shared/BuildingBlocksDiagram.astro';
import { components, categoryLabels } from '../data/components';
---

<BaseLayout
  title="Platform — OpenOva"
  description="Open-source Kubernetes components — core and a la carte. All upstream open source, all AI-manageable."
  path="/platform"
>
  <!-- Hero -->
  <Section>
    <div class="mx-auto max-w-3xl text-center">
      <Badge variant="accent" class="mb-6">Building blocks</Badge>
      <h1 class="text-4xl font-extrabold text-text-primary md:text-5xl">
        Harmonized ecosystem.<br/>Proven interoperability.
      </h1>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        Every component exposes structured CRDs, emits unified OTel telemetry, and is designed to be managed by Specter. This is not a collection of tools. It is an integrated, AI-manageable ecosystem.
      </p>
    </div>
  </Section>

  <!-- Catalyst Lifecycle -->
  <Section bg="secondary">
    <SectionTitle label="Lifecycle">
      One tool from bootstrap to day-2
    </SectionTitle>

    <div class="mx-auto max-w-3xl reveal">
      <Card>
        <div class="mb-3 flex items-center gap-2">
          <Badge variant="accent">Catalyst</Badge>
          <h3 class="font-semibold text-text-primary">Bootstrap, operate, evolve</h3>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed mb-4">
          Catalyst handles the full platform lifecycle. It provisions your initial cluster, manages day-2 operations, provides an Internal Developer Platform for your teams, and gives operators a Workflow Explorer for visibility into every reconciliation.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 mt-4">
          <div>
            <h4 class="text-xs font-semibold text-text-primary mb-2">Bootstrap</h4>
            <ul class="space-y-1 text-sm text-text-secondary">
              <li>Provisions infrastructure and K3s cluster</li>
              <li>Deploys all platform components via GitOps</li>
              <li>Exits cleanly — safe to remove</li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-text-primary mb-2">Day-2 operations</h4>
            <ul class="space-y-1 text-sm text-text-secondary">
              <li>Cloud resources managed as Kubernetes CRDs</li>
              <li>Continuous drift detection and reconciliation</li>
              <li>Self-service via IDP templates</li>
            </ul>
          </div>
        </div>
      </Card>
    </div>
  </Section>

  <!-- Building Blocks -->
  <Section>
    <SectionTitle label="Building blocks">
      Functional layers of the platform
    </SectionTitle>

    <div class="reveal">
      <BuildingBlocksDiagram />
    </div>
  </Section>

  <!-- Interactive Component Grid -->
  <Section bg="secondary">
    <SectionTitle label="Components">
      All components
    </SectionTitle>

    <ComponentGrid
      client:visible
      components={components}
      categoryLabels={categoryLabels}
    />
  </Section>

  <!-- Specter Deep Dive -->
  <Section bg="secondary">
    <SectionTitle label="Specter">
      The AI brain of the platform
    </SectionTitle>

    <div class="mb-8 max-w-3xl reveal">
      <p class="text-lg text-text-secondary leading-relaxed">
        Specter has pre-built semantic knowledge of every CRD schema, integration dependency, failure mode, health check, upgrade path, and compliance mapping across every component. It doesn&rsquo;t dump logs into an LLM. It sends surgical, structured context.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-children">
      {[
        { agent: 'DevOps', desc: 'Drift detection, resource optimization, scaling recommendations, deployment validation' },
        { agent: 'DevSecOps', desc: 'CVE scanning, policy compliance, security posture assessment, vulnerability remediation' },
        { agent: 'SRE', desc: 'Incident correlation, root cause analysis, auto-remediation, runbook execution' },
        { agent: 'FinOps', desc: 'Cost anomaly detection, right-sizing, waste elimination, capacity forecasting' },
        { agent: 'Compliance', desc: 'Continuous audit, evidence collection, report generation, regulatory mapping' },
        { agent: 'AI Ops', desc: 'LLM inference monitoring, model drift detection, GPU utilization, AI safety policy enforcement' },
      ].map((a) => (
        <Card>
          <h3 class="mb-2 font-semibold text-text-primary">{a.agent} Agent</h3>
          <p class="text-sm text-text-secondary">{a.desc}</p>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Multi-Region -->
  <Section>
    <SectionTitle label="Multi-region">
      Built for disaster recovery
    </SectionTitle>

    <div class="grid gap-6 md:grid-cols-2 reveal-children">
      <div>
        <h3 class="mb-4 text-lg font-semibold text-text-primary">Independent clusters</h3>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            2 regions recommended (1 allowed)
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            NOT stretched clusters — independent and resilient
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            k8gb authoritative DNS for GSLB
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Split-brain protection via external DNS witnesses
          </li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-lg font-semibold text-text-primary">Data replication</h3>
        <div class="space-y-2 text-sm">
          {[
            { name: 'PostgreSQL (CNPG)', method: 'WAL streaming' },
            { name: 'Kafka (Strimzi)', method: 'MirrorMaker2' },
            { name: 'Valkey', method: 'REPLICAOF' },
            { name: 'Git (Gitea)', method: 'Bidirectional mirror' },
            { name: 'Registry (Harbor)', method: 'Replication' },
            { name: 'Secrets (OpenBao)', method: 'PushSecrets via ESO' },
          ].map((r) => (
            <div class="flex items-center justify-between rounded-lg border border-border-primary bg-bg-primary px-3 py-2">
              <span class="text-text-primary">{r.name}</span>
              <span class="font-mono text-xs text-text-tertiary">{r.method}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section bg="secondary">
    <div class="mx-auto max-w-2xl text-center reveal">
      <h2 class="text-3xl font-bold text-text-primary">See it in action</h2>
      <p class="mt-4 text-text-secondary">Production-grade, deployed instantly.</p>
      <div class="mt-8">
        <Button href="/contact">Talk to us</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

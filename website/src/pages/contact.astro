---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/shared/Section.astro';
import Card from '../components/shared/Card.astro';
import ContactForm from '../components/islands/ContactForm.svelte';
---

<BaseLayout
  title="Contact — OpenOva"
  description="Talk to us about AI-native infrastructure, migration, or platform support."
  path="/contact"
>
  <Section>
    <div class="grid gap-12 md:grid-cols-2">
      <!-- Form -->
      <div>
        <h1 class="text-3xl font-extrabold text-text-primary md:text-4xl">
          Let&rsquo;s talk
        </h1>
        <p class="mt-4 text-text-secondary leading-relaxed">
          Whether you need a platform assessment, want to explore migration paths, or are ready to deploy &mdash; we&rsquo;re here.
        </p>
        <p class="mt-2 text-sm text-accent">We respond within one business day.</p>

        <div class="mt-8">
          <ContactForm client:visible />
        </div>
      </div>

      <!-- Info side -->
      <div class="space-y-6">
        <Card hover={false}>
          <h3 class="mb-2 font-semibold text-text-primary">Platform assessment</h3>
          <p class="text-sm text-text-secondary">
            Not sure where to start? We offer a free initial consultation to understand your needs and recommend the right approach.
          </p>
        </Card>

        <Card hover={false}>
          <h3 class="mb-2 font-semibold text-text-primary">Migration planning</h3>
          <p class="text-sm text-text-secondary">
            Trapped in OpenShift, VMware, or Datadog? Our Exodus program provides a structured path to open source with zero downtime.
          </p>
        </Card>

        <Card hover={false}>
          <h3 class="mb-2 font-semibold text-text-primary">Technical deep dive</h3>
          <p class="text-sm text-text-secondary">
            Want to see the platform in action? We can walk through the architecture, Specter agents, and deployment process.
          </p>
        </Card>

        <div class="rounded-xl border border-border-primary bg-bg-secondary p-6">
          <h3 class="mb-3 font-semibold text-text-primary">Connect</h3>
          <div class="space-y-2 text-sm">
            <a href="https://github.com/openova-io" class="flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              github.com/openova-io
            </a>
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>

---
interface Props {
  compact?: boolean;
  viewMode?: 0 | 1 | 2;
  interactive?: boolean;
}

const { compact = false, viewMode, interactive = true } = Astro.props;
const isStatic = viewMode !== undefined;

const conceptMap: Record<string, string> = {
  'cert-manager': 'TLS Automation', 'ESO': 'Secrets Sync', 'OpenBao': 'Secrets Vault',
  'Trivy': 'Vuln Scan', 'Falco': 'Runtime Security', 'Sigstore': 'Supply Chain Trust',
  'Syft+Grype': 'SBOM & CVE', 'Kyverno': 'Policy Engine', 'Keycloak': 'IAM',
  'Specter': 'AIOps Brain', 'Grafana': 'Dashboards', 'Alloy': 'Telemetry Agent',
  'Loki': 'Log Aggregation', 'Mimir': 'Metrics Store', 'Tempo': 'Distributed Tracing',
  'OpenTelemetry': 'Instrumentation', 'OpenSearch': 'Search & Analytics',
  'Litmus': 'Chaos Engineering', 'OpenMeter': 'Usage Metering',
  'KServe': 'Model Serving', 'Knative': 'Serverless', 'vLLM': 'LLM Inference',
  'Milvus': 'Vector DB', 'Neo4j': 'Graph DB', 'BGE': 'Embeddings',
  'LibreChat': 'Chat UI', 'NeMo': 'AI Guardrails', 'LangFuse': 'LLM Observability',
  'Axon': 'LLM Gateway',
  'CNPG': 'PostgreSQL', 'FerretDB': 'MongoDB Wire', 'Valkey': 'Redis Cache',
  'Strimzi': 'Event Streaming', 'ClickHouse': 'Analytics DB', 'Flink': 'Stream Processing',
  'Temporal': 'Workflow Engine', 'Debezium': 'CDC', 'Iceberg': 'Data Lakehouse',
  'Fingate': 'Open Banking',
  'Stalwart': 'Email Server', 'LiveKit': 'Video & Audio', 'STUNner': 'WebRTC GW',
  'Matrix': 'Chat Protocol', 'Ntfy': 'Push Notify',
  'Cilium': 'CNI & Mesh', 'Envoy': 'L7 Proxy', 'Coraza': 'WAF',
  'ExternalDNS': 'DNS Sync', 'k8gb': 'GSLB',
  'frpc': 'Reverse Tunnel', 'NetBird': 'Mesh VPN', 'strongSwan': 'IPsec Gateway',
  'Flux': 'GitOps Engine', 'Gitea': 'Git Server', 'OpenTofu': 'IaC',
  'Crossplane': 'Cloud CRDs',
  'VPA': 'Vertical Scaling', 'KEDA': 'Event Scaling', 'Reloader': 'Config Reload',
  'Continuum': 'HA Orchestration',
  'MinIO': 'Object Storage', 'Velero': 'Backup & Restore', 'Harbor': 'Container Registry',
  'Bootstrap Wizard': 'Initial Setup', 'Lifecycle Manager': 'Day-2 Operations',
};

const groupConceptMap: Record<string, string> = {
  'GUARDIAN': 'Security', 'INSIGHTS': 'AIOps',
  'CORTEX': 'AI Hub', 'FABRIC': 'Data & Integration', 'RELAY': 'Communication',
  'SPINE': 'Networking & Mesh', 'PILOT': 'GitOps & IaC',
  'SURGE': 'Scaling & Resilience', 'SILO': 'Storage & Registry',
  'CATALYST': 'Bootstrap & Lifecycle',
};

const groupDescMap: Record<string, string> = {
  'GUARDIAN': 'Certs, secrets, scanning, runtime security, policy, IAM',
  'INSIGHTS': 'Dashboards, metrics, logs, traces, AI ops, chaos testing',
  'CORTEX': 'LLM serving, RAG, vector search, AI safety, observability',
  'FABRIC': 'PostgreSQL, streaming, workflows, CDC, data lakehouse',
  'RELAY': 'Email, video, team chat, WebRTC gateway',
  'SPINE': 'Service mesh, L7 proxy, WAF, DNS, GSLB, VPN, tunnels',
  'PILOT': 'GitOps delivery, IaC, cloud resource management',
  'SURGE': 'Vertical & event scaling, config reload, HA',
  'SILO': 'Object storage, backup & restore, container registry',
  'CATALYST': 'Bootstrap wizard, lifecycle manager for Day-2 ops',
};

const guardianComponents = ['cert-manager', 'ESO', 'OpenBao', 'Trivy', 'Falco', 'Sigstore', 'Syft+Grype', 'Kyverno', 'Keycloak'];
const insightsOSS = ['Grafana', 'Alloy', 'Loki', 'Mimir', 'Tempo', 'OpenTelemetry', 'OpenSearch', 'Litmus', 'OpenMeter'];

const alacarteGroups = [
  { label: 'CORTEX', color: '#F97316', components: ['KServe', 'Knative', 'vLLM', 'Milvus', 'Neo4j', 'BGE', 'LibreChat', 'NeMo', 'LangFuse'], products: ['Axon'] },
  { label: 'FABRIC', color: '#EC4899', components: ['CNPG', 'FerretDB', 'Valkey', 'Strimzi', 'ClickHouse', 'Flink', 'Temporal', 'Debezium', 'Iceberg'], products: ['Fingate'] },
];
const relayGroup = { label: 'RELAY', color: '#06B6D4', components: ['Stalwart', 'LiveKit', 'STUNner', 'Matrix', 'Ntfy'], products: [] as string[] };

const coreGroups = [
  { label: 'PILOT', color: '#8B5CF6', components: ['Flux', 'Gitea', 'OpenTofu', 'Crossplane'], products: [] as string[] },
  { label: 'SPINE', color: '#3B82F6', components: ['Cilium', 'Envoy', 'Coraza', 'ExternalDNS', 'k8gb', 'frpc', 'NetBird', 'strongSwan'], products: [] as string[] },
  { label: 'SURGE', color: '#14B8A6', components: ['VPA', 'KEDA', 'Reloader'], products: ['Continuum'] },
  { label: 'SILO', color: '#6366F1', components: ['MinIO', 'Velero', 'Harbor'], products: [] as string[] },
];

const catalystModules = [
  { name: 'Bootstrap Wizard', product: true },
  { name: 'Lifecycle Manager', product: true },
];

const clouds = ['Huawei Cloud', 'AWS', 'Oracle OCI', 'Hetzner'];

// For static viewMode rendering: show correct chip text at build time
const chipLabel = (name: string) => {
  if (viewMode === 1) return conceptMap[name] || name;
  return name;
};
---

{/* ═══ INTERACTIVE MODE: Toggle between concepts and products ═══ */}
{!isStatic && (
<div class="arch-interactive-wrapper">
  <div class="arch__toggle">
    <button class="arch__toggle-btn arch__toggle-btn--active" data-view="concepts">Concepts</button>
    <button class="arch__toggle-btn" data-view="tech">Products</button>
  </div>
  <div class:list={['arch', 'arch--view-2', 'arch--static', 'arch--concepts', { 'arch--compact': compact }]}>
    <div class="arch__body">
      <div class="arch__side arch__side--guardian">
        <span class="arch__side-label" data-tech="GUARDIAN" data-concept={groupConceptMap['GUARDIAN']}>{groupConceptMap['GUARDIAN']}</span>
        <div class="arch__side-chips">
          {guardianComponents.map(c => (
            <span class="arch__chip arch__chip--guardian arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{conceptMap[c]}</span>
          ))}
        </div>
      </div>

      <div class="arch__center">
        <div class="arch__groups arch__groups--alacarte">
          {alacarteGroups.map(g => (
            <div class="arch__group" data-group={g.label} style={`--gc: ${g.color}; border-color: ${g.color}30; background: ${g.color}12;`}>
              <span class="arch__group-label" data-tech={g.label} data-concept={groupConceptMap[g.label]} style={`color: ${g.color};`}>{groupConceptMap[g.label]}</span>
              <div class="arch__chips arch__chips--spread">
                {g.components.map(c => (
                  <span class="arch__chip arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{conceptMap[c]}</span>
                ))}
                {g.products.map(p => (
                  <span class="arch__chip arch__chip--product arch__chip--flip" data-tech={p} data-concept={conceptMap[p]}>{conceptMap[p]}</span>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="arch__group arch__group--fullwidth" data-group={relayGroup.label} style={`--gc: ${relayGroup.color}; border-color: ${relayGroup.color}30; background: ${relayGroup.color}12;`}>
          <span class="arch__group-label" data-tech={relayGroup.label} data-concept={groupConceptMap[relayGroup.label]} style={`color: ${relayGroup.color};`}>{groupConceptMap[relayGroup.label]}</span>
          <div class="arch__chips arch__chips--spread">
            {relayGroup.components.map(c => (
              <span class="arch__chip arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{conceptMap[c]}</span>
            ))}
          </div>
        </div>

        <div class="arch__groups arch__groups--core">
          {coreGroups.map(g => (
            <div class="arch__group" data-group={g.label} style={`--gc: ${g.color}; border-color: ${g.color}30; background: ${g.color}12;`}>
              <span class="arch__group-label" data-tech={g.label} data-concept={groupConceptMap[g.label]} style={`color: ${g.color};`}>{groupConceptMap[g.label]}</span>
              <div class="arch__chips arch__chips--spread">
                {g.components.map(c => (
                  <span class="arch__chip arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{conceptMap[c]}</span>
                ))}
                {g.products.map(p => (
                  <span class="arch__chip arch__chip--product arch__chip--flip" data-tech={p} data-concept={conceptMap[p]}>{conceptMap[p]}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="arch__side arch__side--insights">
        <span class="arch__side-label" data-tech="INSIGHTS" data-concept={groupConceptMap['INSIGHTS']}>{groupConceptMap['INSIGHTS']}</span>
        <div class="arch__side-chips">
          <span class="arch__chip arch__chip--product arch__chip--product-insights arch__chip--flip" data-tech="Specter" data-concept={conceptMap['Specter']}>{conceptMap['Specter']}</span>
          {insightsOSS.map(c => (
            <span class="arch__chip arch__chip--insights arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{conceptMap[c]}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="arch__group arch__group--catalyst" style="--gc: #3B82F6; border-color: #3B82F625; background: #3B82F610;">
      <span class="arch__group-label" data-tech="CATALYST" data-concept={groupConceptMap['CATALYST']} style="color: #3B82F6;">{groupConceptMap['CATALYST']}</span>
      <div class="arch__chips arch__chips--spread">
        {catalystModules.map(m => (
          <span class:list={['arch__chip', 'arch__chip--flip', { 'arch__chip--product': m.product }]} data-tech={m.name} data-concept={conceptMap[m.name]}>{conceptMap[m.name]}</span>
        ))}
      </div>
    </div>

    <div class="arch__bar arch__bar--k8s">
      <span class="arch__bar-name">Kubernetes (K3s)</span>
    </div>

    <div class="arch__clouds">
      {clouds.map(c => (
        <div class="arch__cloud">{c}</div>
      ))}
    </div>
  </div>
</div>
)}

{/* ═══ STATIC MODE: viewMode rendering for homepage carousel ═══ */}
{isStatic && (
<div class:list={[
  'arch',
  `arch--view-${viewMode ?? 0}`,
  { 'arch--compact': compact },
  'arch--static',
  { 'arch--no-interact': !interactive },
]}>
  <div class="arch__body">
    <!-- Guardian vertical -->
    <div class="arch__side arch__side--guardian">
      <span class="arch__side-label">{(viewMode === 0 || viewMode === 1) ? groupConceptMap['GUARDIAN'] : 'GUARDIAN'}</span>
      <div class="arch__side-chips">
        {guardianComponents.map(c => (
          <span class="arch__chip arch__chip--guardian arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{chipLabel(c)}</span>
        ))}
      </div>
      {viewMode === 0 && (
        <div class="arch__side-desc">
          <span class="arch__side-desc-title">Guardian</span>
          <span class="arch__side-desc-text">{groupDescMap['GUARDIAN']}</span>
          <span class="arch__side-count">{guardianComponents.length}</span>
        </div>
      )}
    </div>

    <!-- Center content -->
    <div class="arch__center">
      <!-- A la carte: 2-column (Cortex | Fabric) -->
      <div class="arch__groups arch__groups--alacarte">
        {alacarteGroups.map(g => (
          <div class="arch__group" data-group={g.label} style={`--gc: ${g.color}; border-color: ${g.color}30; background: ${g.color}12;`}>
            <span class="arch__group-label" style={`color: ${g.color};`}>{(viewMode === 0 || viewMode === 1) ? groupConceptMap[g.label] : g.label}</span>
            <div class="arch__chips arch__chips--spread">
              {g.components.map(c => (
                <span class="arch__chip arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{chipLabel(c)}</span>
              ))}
              {g.products.map(p => (
                <span class="arch__chip arch__chip--product arch__chip--flip" data-tech={p} data-concept={conceptMap[p]}>{chipLabel(p)}</span>
              ))}
            </div>
            {viewMode === 0 && (
              <div class="arch__group-desc">
                <span class="arch__group-desc-title" style={`color: ${g.color};`}>{g.label}</span>
                <span class="arch__group-desc-text">{groupDescMap[g.label]}</span>
                <span class="arch__group-desc-count">{g.components.length + g.products.length}</span>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Relay -->
      <div class="arch__group arch__group--fullwidth" data-group={relayGroup.label} style={`--gc: ${relayGroup.color}; border-color: ${relayGroup.color}30; background: ${relayGroup.color}12;`}>
        <span class="arch__group-label" style={`color: ${relayGroup.color};`}>{(viewMode === 0 || viewMode === 1) ? groupConceptMap[relayGroup.label] : relayGroup.label}</span>
        <div class="arch__chips arch__chips--spread">
          {relayGroup.components.map(c => (
            <span class="arch__chip arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{chipLabel(c)}</span>
          ))}
        </div>
        {viewMode === 0 && (
          <div class="arch__group-desc">
            <span class="arch__group-desc-title" style={`color: ${relayGroup.color};`}>{relayGroup.label}</span>
            <span class="arch__group-desc-text">{groupDescMap[relayGroup.label]}</span>
            <span class="arch__group-desc-count">{relayGroup.components.length}</span>
          </div>
        )}
      </div>

      <!-- Core platform -->
      <div class="arch__groups arch__groups--core">
        {coreGroups.map(g => (
          <div class="arch__group" data-group={g.label} style={`--gc: ${g.color}; border-color: ${g.color}30; background: ${g.color}12;`}>
            <span class="arch__group-label" style={`color: ${g.color};`}>{(viewMode === 0 || viewMode === 1) ? groupConceptMap[g.label] : g.label}</span>
            <div class="arch__chips arch__chips--spread">
              {g.components.map(c => (
                <span class="arch__chip arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{chipLabel(c)}</span>
              ))}
              {g.products.map(p => (
                <span class="arch__chip arch__chip--product arch__chip--flip" data-tech={p} data-concept={conceptMap[p]}>{chipLabel(p)}</span>
              ))}
            </div>
            {viewMode === 0 && (
              <div class="arch__group-desc">
                <span class="arch__group-desc-title" style={`color: ${g.color};`}>{g.label}</span>
                <span class="arch__group-desc-text">{groupDescMap[g.label]}</span>
                <span class="arch__group-desc-count">{g.components.length + g.products.length}</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Insights vertical -->
    <div class="arch__side arch__side--insights">
      <span class="arch__side-label">{(viewMode === 0 || viewMode === 1) ? groupConceptMap['INSIGHTS'] : 'INSIGHTS'}</span>
      <div class="arch__side-chips">
        <span class="arch__chip arch__chip--product arch__chip--product-insights arch__chip--flip" data-tech="Specter" data-concept={conceptMap['Specter']}>{chipLabel('Specter')}</span>
        {insightsOSS.map(c => (
          <span class="arch__chip arch__chip--insights arch__chip--flip" data-tech={c} data-concept={conceptMap[c]}>{chipLabel(c)}</span>
        ))}
      </div>
      {viewMode === 0 && (
        <div class="arch__side-desc">
          <span class="arch__side-desc-title">Insights</span>
          <span class="arch__side-desc-text">{groupDescMap['INSIGHTS']}</span>
          <span class="arch__side-count">{insightsOSS.length + 1}</span>
        </div>
      )}
    </div>
  </div>

  <!-- Catalyst -->
  <div class="arch__group arch__group--catalyst" style="--gc: #3B82F6; border-color: #3B82F625; background: #3B82F610;">
    <span class="arch__group-label" style="color: #3B82F6;">{(viewMode === 0 || viewMode === 1) ? groupConceptMap['CATALYST'] : 'CATALYST'}</span>
    <div class="arch__chips arch__chips--spread">
      {catalystModules.map(m => (
        <span class:list={['arch__chip', 'arch__chip--flip', { 'arch__chip--product': m.product }]} data-tech={m.name} data-concept={conceptMap[m.name]}>{chipLabel(m.name)}</span>
      ))}
    </div>
    {viewMode === 0 && (
      <div class="arch__group-desc">
        <span class="arch__group-desc-title" style="color: #3B82F6;">CATALYST</span>
        <span class="arch__group-desc-text">{groupDescMap['CATALYST']}</span>
        <span class="arch__group-desc-count">2</span>
      </div>
    )}
  </div>

  <!-- Kubernetes -->
  <div class="arch__bar arch__bar--k8s">
    <span class="arch__bar-name">Kubernetes (K3s)</span>
  </div>

  <!-- Cloud providers -->
  <div class="arch__clouds">
    {clouds.map(c => (
      <div class="arch__cloud">{c}</div>
    ))}
  </div>
</div>
)}


<style>
  /* ══════════════════════════════════════════
     STATIC MODE (arch__ prefix — homepage)
     ══════════════════════════════════════════ */

  .arch {
    border: 1px solid var(--color-border-primary);
    border-radius: 0.75rem;
    overflow: hidden;
    font-family: inherit;
    max-width: 40rem;
    margin: 0 auto;
  }

  /* ── Uniform labels ── */
  .arch__side-label,
  .arch__group-label,
  .arch__bar-name {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-weight: 700;
    font-size: 0.5625rem;
    letter-spacing: 0.06em;
  }

  /* ── K8s bar ── */
  .arch__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.1875rem 0.375rem;
  }
  .arch__bar-name { flex-shrink: 0; }
  .arch__bar--k8s {
    background: #64748B0c;
    border-bottom: 1px solid #64748B20;
    color: #94A3B8;
  }

  /* ── Main body (3-column) ── */
  .arch__body {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr) 5rem;
    gap: 0.25rem;
  }

  /* ── Vertical side bars ── */
  .arch__side {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.25rem 0.125rem;
    gap: 0.125rem;
    border-radius: 0.25rem;
  }
  .arch__side-label {
    text-align: center;
    line-height: 1.3;
  }
  .arch__side-chips {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: space-evenly;
    width: 100%;
    gap: 0;
  }
  .arch__side--guardian {
    background: #EF444410;
    border: 1px solid #EF444425;
    color: #EF4444;
  }
  .arch__side--insights {
    background: #A855F710;
    border: 1px solid #A855F725;
    color: #A855F7;
  }

  /* ── Center content ── */
  .arch__center {
    padding: 0.375rem 0.1875rem 0.1875rem;
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
  }

  /* ── Groups grid ── */
  .arch__groups {
    display: grid;
    gap: 0.25rem;
  }
  .arch__groups--alacarte {
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 1fr;
  }
  .arch__groups--core {
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 1fr;
  }
  .arch__groups--core .arch__group[data-group="PILOT"] { grid-column: span 2; }
  .arch__groups--core .arch__group[data-group="SPINE"] { grid-column: span 4; }
  .arch__groups--core .arch__group[data-group="SURGE"] { grid-column: span 3; }
  .arch__groups--core .arch__group[data-group="SILO"]  { grid-column: span 3; }

  /* ── Group box ── */
  .arch__group {
    border: 1px solid;
    border-radius: 0.25rem;
    padding: 0.3125rem 0.1875rem 0.125rem;
    position: relative;
    overflow: visible;
  }
  .arch__group-label {
    position: absolute;
    top: 0;
    left: 0.25rem;
    transform: translateY(-50%);
    padding: 0 0.125rem;
    line-height: 1;
    background: var(--color-bg-primary, #0a0a0b);
  }
  .arch__group--fullwidth { }
  .arch__group--catalyst {
    border-radius: 0;
    border-left: none;
    border-right: none;
    padding: 0.3125rem 0.5rem 0.125rem;
  }

  /* ── Divider ── */
  .arch__divider {
    border-top: 1px dashed var(--color-border-primary);
    margin: 0.125rem 0;
  }

  /* ── Chips ── */
  .arch__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.125rem;
    overflow: visible;
  }
  .arch__chips--spread {
    justify-content: space-evenly;
  }
  .arch__chip {
    display: inline-block;
    border-radius: 0.1875rem;
    border: 1px solid var(--color-border-primary);
    background: var(--color-bg-primary, #0a0a0b);
    padding: 0.0625rem 0.1875rem;
    font-size: 0.5625rem;
    color: var(--color-text-secondary);
    line-height: 1.3;
    cursor: default;
    position: relative;
  }
  .arch__chip--guardian {
    border-color: #EF444425;
    color: #FCA5A5;
    background: #EF44440a;
  }
  .arch__chip--insights {
    border-color: #A855F725;
    color: #C4B5FD;
    background: #A855F70a;
  }
  .arch__chip--product {
    border-color: #4B8B6E;
    border-width: 1.5px;
    font-weight: 600;
  }
  .arch__chip--product-insights {
    border-color: #4B8B6E;
    border-width: 1.5px;
    color: #C4B5FD;
    background: #A855F70a;
  }

  /* ── Hover overlay (static) ── */
  .arch__chip--flip:hover::after {
    content: attr(data-concept);
    position: absolute;
    top: -1px; left: -1px; bottom: -1px;
    min-width: calc(100% + 2px);
    width: max-content;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #374151;
    color: #F3F4F6;
    border: 1px solid #6B7280;
    border-radius: inherit;
    font-size: inherit;
    font-weight: 600;
    line-height: inherit;
    padding: 0.0625rem 0.1875rem;
    white-space: nowrap;
    z-index: 2;
  }
  .arch--view-1 .arch__chip--flip:hover::after {
    content: attr(data-tech);
  }
  .arch--view-0 .arch__chip--flip:hover::after {
    display: none;
  }

  /* ── Cloud providers ── */
  .arch__clouds {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .arch__cloud {
    text-align: center;
    padding: 0.1875rem;
    font-size: 0.5rem;
    color: #94A3B8;
    border-right: 1px solid var(--color-border-primary);
    background: var(--color-bg-secondary, #111);
  }
  .arch__cloud:last-child { border-right: none; }


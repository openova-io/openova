</style>

<script>
  function initArchToggle() {
    document.querySelectorAll('.arch-interactive-wrapper').forEach(wrapper => {
      const arch = wrapper.querySelector('.arch');
      if (!arch) return;
      const btns = wrapper.querySelectorAll('.arch__toggle-btn');

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          const view = btn.dataset.view;
          btns.forEach(b => b.classList.remove('arch__toggle-btn--active'));
          btn.classList.add('arch__toggle-btn--active');

          const isConcepts = view === 'concepts';

          // Swap chip text
          arch.querySelectorAll('.arch__chip--flip').forEach(chip => {
            chip.textContent = isConcepts
              ? (chip.dataset.concept || chip.textContent)
              : (chip.dataset.tech || chip.textContent);
          });

          // Swap group and side labels
          arch.querySelectorAll('.arch__group-label[data-tech], .arch__side-label[data-tech]').forEach(label => {
            label.textContent = isConcepts
              ? (label.dataset.concept || label.textContent)
              : (label.dataset.tech || label.textContent);
          });

          // Toggle class for hover CSS
          arch.classList.toggle('arch--concepts', isConcepts);
        });
      });
    });
  }

  initArchToggle();
  document.addEventListener('astro:after-swap', initArchToggle);
</script>

---
import Section from '../shared/Section.astro';
import Button from '../shared/Button.astro';
---

<Section bg="secondary">
  <div class="mx-auto max-w-2xl text-center reveal">
    <h2 class="text-3xl font-bold text-text-primary md:text-4xl">
      Ready to stop building infrastructure and start building product?
    </h2>
    <p class="mt-4 text-lg text-text-secondary">
      What takes 2-3 years to build internally, we deploy instantly.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button href="/contact">Talk to us</Button>
      <Button href="/platform" variant="secondary">Explore the platform</Button>
    </div>
  </div>
</Section>

---
import Section from '../shared/Section.astro';
import SectionTitle from '../shared/SectionTitle.astro';
import Button from '../shared/Button.astro';
---

<Section bg="secondary">
  <SectionTitle label="ROI">
    The economics are clear
  </SectionTitle>

  <div class="grid gap-4 sm:grid-cols-3 reveal-children">
    <div class="rounded-xl border border-border-primary bg-bg-primary p-6 text-center">
      <p class="text-3xl font-bold text-accent">60-85%</p>
      <p class="mt-1 text-sm text-text-tertiary">cost savings vs status quo</p>
    </div>
    <div class="rounded-xl border border-border-primary bg-bg-primary p-6 text-center">
      <p class="text-3xl font-bold text-accent">&lt; 3 mo</p>
      <p class="mt-1 text-sm text-text-tertiary">payback period</p>
    </div>
    <div class="rounded-xl border border-border-primary bg-bg-primary p-6 text-center">
      <p class="text-3xl font-bold text-accent">70%+</p>
      <p class="mt-1 text-sm text-text-tertiary">SOC/NOC team reduction</p>
    </div>
  </div>

  <div class="mt-8 text-center reveal">
    <Button href="/engagement" variant="secondary">See engagement model &rarr;</Button>
  </div>
</Section>

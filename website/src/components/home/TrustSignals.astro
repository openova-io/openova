---
import Section from '../shared/Section.astro';
import SectionTitle from '../shared/SectionTitle.astro';
import Badge from '../shared/Badge.astro';
---

<Section>
  <SectionTitle label="Trust & compliance">
    Enterprise-grade from day one
  </SectionTitle>

  <div class="grid gap-8 md:grid-cols-2 reveal-children">
    <!-- Compliance badges -->
    <div>
      <h3 class="mb-4 text-lg font-semibold text-text-primary">Compliance-ready</h3>
      <div class="flex flex-wrap gap-3">
        {['PSD2', 'DORA', 'NIS2', 'SOX', 'GDPR'].map((badge) => (
          <div class="flex items-center gap-2 rounded-lg border border-border-primary bg-bg-secondary px-4 py-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="text-sm font-medium text-text-primary">{badge}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Zero-trust features -->
    <div>
      <h3 class="mb-4 text-lg font-semibold text-text-primary">Zero-trust security</h3>
      <div class="space-y-3">
        {[
          'eBPF-enforced network policies via Cilium',
          'Mutual TLS everywhere via service mesh',
          'Kyverno auto-generates PDBs and NetworkPolicies',
          'Trivy scanning in CI/CD, registry, and runtime',
          'Falco runtime eBPF threat detection',
          'Coraza WAF with OWASP Core Rule Set',
          'Air-gap capable for sovereign deployments',
        ].map((feature) => (
          <div class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0 text-accent"><path d="M13.3 4.3L6 11.6 2.7 8.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="text-sm text-text-secondary">{feature}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</Section>

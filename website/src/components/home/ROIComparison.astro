---
import Section from '../shared/Section.astro';
import SectionTitle from '../shared/SectionTitle.astro';
import NumberCounter from '../islands/NumberCounter.svelte';
---

<Section bg="secondary">
  <SectionTitle label="ROI">
    The economics are clear
  </SectionTitle>

  <div class="grid gap-8 md:grid-cols-2 reveal-children">
    <!-- Status Quo -->
    <div class="rounded-xl border border-red-500/20 bg-bg-primary p-8">
      <div class="mb-6 flex items-center gap-2">
        <span class="h-3 w-3 rounded-full bg-red-500"></span>
        <h3 class="text-lg font-semibold text-text-primary">Status quo</h3>
      </div>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between"><span class="text-text-secondary">Platform licensing</span><span class="text-text-primary">&euro;150-300K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Observability SaaS</span><span class="text-text-primary">&euro;200-400K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Database licensing</span><span class="text-text-primary">&euro;100-300K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Security tooling</span><span class="text-text-primary">&euro;100-200K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Identity SaaS</span><span class="text-text-primary">&euro;50-150K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Platform team (5-10)</span><span class="text-text-primary">&euro;500K-1.2M</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">SOC/NOC team (5-10)</span><span class="text-text-primary">&euro;500K-1M</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">External consulting</span><span class="text-text-primary">&euro;200-500K</span></div>
      </div>
      <div class="mt-6 border-t border-border-primary pt-4">
        <div class="flex items-baseline justify-between">
          <span class="text-text-secondary">Annual total</span>
          <span class="text-2xl font-bold text-red-400">
            &euro;<NumberCounter client:visible target={1800000} suffix="-4M" duration={1800} />
          </span>
        </div>
      </div>
    </div>

    <!-- OpenOva -->
    <div class="rounded-xl border border-accent/30 bg-bg-primary p-8">
      <div class="mb-6 flex items-center gap-2">
        <span class="h-3 w-3 rounded-full bg-accent"></span>
        <h3 class="text-lg font-semibold text-text-primary">With OpenOva</h3>
      </div>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between"><span class="text-text-secondary">Platform support</span><span class="text-text-primary">&euro;50-200K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Managed operations</span><span class="text-text-primary">&euro;50-150K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Expert network hours</span><span class="text-text-primary">&euro;30-100K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Deployment (amortized)</span><span class="text-text-primary">&euro;30-100K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">Platform team (2-3)</span><span class="text-text-primary">&euro;200-400K</span></div>
        <div class="flex justify-between"><span class="text-text-secondary">SOC/NOC (Specter + 1)</span><span class="text-text-primary">&euro;100-200K</span></div>
      </div>
      <div class="mt-6 border-t border-border-primary pt-4">
        <div class="flex items-baseline justify-between">
          <span class="text-text-secondary">Annual total</span>
          <span class="text-2xl font-bold text-accent">
            &euro;<NumberCounter client:visible target={460000} suffix="K-1.15M" duration={1800} />
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-3 gap-4 reveal-children">
    <div class="rounded-xl border border-border-primary bg-bg-primary p-6 text-center">
      <p class="text-3xl font-bold text-accent">60-85%</p>
      <p class="mt-1 text-sm text-text-tertiary">cost savings</p>
    </div>
    <div class="rounded-xl border border-border-primary bg-bg-primary p-6 text-center">
      <p class="text-3xl font-bold text-accent">&lt; 3 mo</p>
      <p class="mt-1 text-sm text-text-tertiary">payback period</p>
    </div>
    <div class="rounded-xl border border-border-primary bg-bg-primary p-6 text-center">
      <p class="text-3xl font-bold text-accent">70%+</p>
      <p class="mt-1 text-sm text-text-tertiary">SOC/NOC reduction</p>
    </div>
  </div>
</Section>

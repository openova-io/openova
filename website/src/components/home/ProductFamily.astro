---
import Section from '../shared/Section.astro';
import SectionTitle from '../shared/SectionTitle.astro';
import ProductCarousel from '../islands/ProductCarousel.svelte';
import { products } from '../../data/products';
---

<Section>
  <SectionTitle label="Product family">
    Nine products. One ecosystem.
  </SectionTitle>

  <div class="reveal">
    <ProductCarousel client:visible products={products} />
  </div>
</Section>

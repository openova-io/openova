---
const year = new Date().getFullYear();
---

<footer class="border-t border-border-primary bg-bg-primary">
  <div class="mx-auto max-w-7xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-4">
      <div>
        <a href="/" class="flex items-center gap-2 text-text-primary">
          <img src="/logos/logo2.svg" width="28" height="28" alt="OpenOva" aria-hidden="true" />
          <span class="text-lg font-bold"><span style="color: #10B981">Open</span><span style="color: #06B6D4">Ova</span></span>
        </a>
        <p class="mt-4 text-sm text-text-tertiary leading-relaxed">
          The converged cloud-native platform.<br/>
          Open-source components.<br/>
          Production-grade interoperability.
        </p>
      </div>

      <div>
        <h3 class="mb-4 font-medium text-text-primary">Platform</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/platform" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Components</a></li>
          <li><a href="/solutions" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Solutions</a></li>
          <li><a href="/docs" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Docs</a></li>
          <li><a href="/engagement" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Engagement</a></li>
          <li><a href="/exodus" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Migration</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-medium text-text-primary">Company</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/about" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Contact</a></li>
          <li><a href="https://github.com/openova-io" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-medium text-text-primary">Legal</h3>
        <ul class="flex flex-col gap-2">
          <li><span class="text-sm text-text-tertiary">All blueprints open source</span></li>
          <li><span class="text-sm text-text-tertiary">Free forever</span></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border-primary pt-8 md:flex-row">
      <p class="text-sm text-text-tertiary">
        &copy; {year} OpenOva. All software free and open source.
      </p>
      <p class="text-sm text-text-tertiary">
        Cloud-native is the foundation. AI-native is the differentiator.
      </p>
    </div>
  </div>
</footer>
